{
  "productName": "PathMaid",
  "version": "1.5.3",
  "identifier": "com.pathmaid.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PathMaid",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": [28, 19, 9, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDNjVEMzRDNEExMTFBNzgKUldSNEdoRktUTk5sN0dnQk8zYmxrL3VTbVd3YXJVekt5ZkJEUnlsdGdYZmtnaWd0Zk44M29RTmsK",
      "endpoints": [
        "https://github.com/kirylyaskou/PathMaid/releases/latest/download/latest.json"
      ]
    }
  }
}
